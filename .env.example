# Environment Configuration for Enterprise QA System

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# OpenAI API
OPENAI_API_KEY=your-openai-api-key

# MinIO Storage
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=minioadmin

# Security Settings (optional)
SECURITY_LEVEL=medium
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Redis Cache (optional)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch (optional)
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# Monitoring (optional)
PROMETHEUS_PORT=9090

# Service Configuration (optional)
QA_SERVICE_URL=http://qa_service:8002
AUTH_SERVICE_URL=http://auth_service:8001
VECTOR_STORE_URL=http://vector_store_service:8004
BM25_CACHE_URL=http://bm25_cache_service:8005

# Notes:
# - Change all default passwords and secrets before production deployment
# - Use a password manager or secrets management tool in production
# - Consider using docker secrets or Kubernetes secrets for sensitive data
